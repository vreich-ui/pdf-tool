type WorkflowInput = { input_as_text: string };


// Main code entrypoint
export const runWorkflow = async (workflow: WorkflowInput) => {
  return await withTrace("Copy of Writer and Publisher 2.1", async () => {
    const state = {
      articlemd: null,
      test_mode: true,
      research_summary: "No research available",
      reader_insight: "No reader insight",
      hidden_concern: null,
      desired_outcome: null,
      reader_starting_state: null
    };
    const conversationHistory: AgentInputItem[] = [
      { role: "user", content: [{ type: "input_text", text: workflow.input_as_text }] }
    ];
    const runner = new Runner({
      traceMetadata: {
        __trace_source__: "agent-builder",
        workflow_id: "wf_6a0f2e255c88819093dc7ab41388cd3604f59d499432c911"
      }
    });
    const topicOpportunityAgentResultTemp = await runner.run(
      topicOpportunityAgent,
      [
        ...conversationHistory
      ],
      {
        context: {
          workflowInputAsText: workflow.input_as_text
        }
      }
    );
    conversationHistory.push(...topicOpportunityAgentResultTemp.newItems.map((item) => item.rawItem));

    if (!topicOpportunityAgentResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const topicOpportunityAgentResult = {
      output_text: topicOpportunityAgentResultTemp.finalOutput ?? ""
    };
    const researchResultTemp = await runner.run(
      research,
      [
        ...conversationHistory
      ],
      {
        context: {
          workflowInputAsText: workflow.input_as_text
        }
      }
    );
    conversationHistory.push(...researchResultTemp.newItems.map((item) => item.rawItem));

    if (!researchResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const researchResult = {
      output_text: JSON.stringify(researchResultTemp.finalOutput),
      output_parsed: researchResultTemp.finalOutput
    };
    const readerInsightAgentResultTemp = await runner.run(
      readerInsightAgent,
      [
        ...conversationHistory
      ],
      {
        context: {
          stateResearchSummary: state.research_summary,
          workflowInputAsText: workflow.input_as_text
        }
      }
    );
    conversationHistory.push(...readerInsightAgentResultTemp.newItems.map((item) => item.rawItem));

    if (!readerInsightAgentResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const readerInsightAgentResult = {
      output_text: JSON.stringify(readerInsightAgentResultTemp.finalOutput),
      output_parsed: readerInsightAgentResultTemp.finalOutput
    };
    const objectionMappingAgentResultTemp = await runner.run(
      objectionMappingAgent,
      [
        ...conversationHistory
      ],
      {
        context: {
          workflowInputAsText: workflow.input_as_text,
          inputOutputParsedReaderStartingState: readerInsightAgentResult.output_parsed.reader_starting_state,
          inputOutputParsedFeltProblem: readerInsightAgentResult.output_parsed.felt_problem,
          inputOutputParsedHiddenConcern: readerInsightAgentResult.output_parsed.hidden_concern,
          inputOutputParsedDesiredOutcome: readerInsightAgentResult.output_parsed.desired_outcome,
          inputOutputParsedLikelyReaderBelief: readerInsightAgentResult.output_parsed.likely_reader_belief,
          inputOutputParsedCoreConfusion: readerInsightAgentResult.output_parsed.core_confusion,
          inputOutputParsedEmotionalGoal: readerInsightAgentResult.output_parsed.emotional_goal,
          inputOutputParsedDesiredEndingState: readerInsightAgentResult.output_parsed.desired_ending_state
        }
      }
    );
    conversationHistory.push(...objectionMappingAgentResultTemp.newItems.map((item) => item.rawItem));

    if (!objectionMappingAgentResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const objectionMappingAgentResult = {
      output_text: JSON.stringify(objectionMappingAgentResultTemp.finalOutput),
      output_parsed: objectionMappingAgentResultTemp.finalOutput
    };
    const narrativeMovementAgentResultTemp = await runner.run(
      narrativeMovementAgent,
      [
        ...conversationHistory
      ]
    );
    conversationHistory.push(...narrativeMovementAgentResultTemp.newItems.map((item) => item.rawItem));

    if (!narrativeMovementAgentResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const narrativeMovementAgentResult = {
      output_text: JSON.stringify(narrativeMovementAgentResultTemp.finalOutput),
      output_parsed: narrativeMovementAgentResultTemp.finalOutput
    };
    const angleStrategistResultTemp = await runner.run(
      angleStrategist,
      [
        ...conversationHistory
      ]
    );
    conversationHistory.push(...angleStrategistResultTemp.newItems.map((item) => item.rawItem));

    if (!angleStrategistResultTemp.finalOutput) {
        throw new Error("Agent result is undefined");
    }

    const angleStrategistResult = {
      output_text: JSON.stringify(angleStrategistResultTemp.finalOutput),
      output_parsed: angleStrategistResultTemp.finalOutput
    };
    const approvalMessage = `Approve or reject the recommended article angle.

  Approve if:
  - the angle is useful for Dr. Lurie Skincare readers
  - the promise feels calm, clear, and trustworthy
  - the emotional tension is believable
  - the topic is worth drafting
  - the monetization path is subtle and natural

  Reject if:
  - the angle feels generic
  - the topic feels too risky or too medical
  - the promise overreaches
  - the emotional framing feels forced
  - the article should not be drafted yet

  Review the Angle Strategist output before deciding.

  Recommended angle:
  ${angleStrategistResult.output_parsed.recommended_angle.angle}

  Why this angle:
  ${angleStrategistResult.output_parsed.recommended_angle.why_this_angle}

  What writer should avoid:
  ${angleStrategistResult.output_parsed.recommended_angle.what_writer_should_avoid}`;

    if (approvalRequest(approvalMessage)) {
        const briefArchitectResultTemp = await runner.run(
          briefArchitect,
          [
            ...conversationHistory
          ]
        );
        conversationHistory.push(...briefArchitectResultTemp.newItems.map((item) => item.rawItem));

        if (!briefArchitectResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const briefArchitectResult = {
          output_text: JSON.stringify(briefArchitectResultTemp.finalOutput),
          output_parsed: briefArchitectResultTemp.finalOutput
        };
        const fullDraftWriterResultTemp = await runner.run(
          fullDraftWriter,
          [
            ...conversationHistory
          ],
          {
            context: {
              stateResearchSummary: state.research_summary
            }
          }
        );
        conversationHistory.push(...fullDraftWriterResultTemp.newItems.map((item) => item.rawItem));

        if (!fullDraftWriterResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const fullDraftWriterResult = {
          output_text: JSON.stringify(fullDraftWriterResultTemp.finalOutput),
          output_parsed: fullDraftWriterResultTemp.finalOutput
        };
        const humanTextureEditorResultTemp = await runner.run(
          humanTextureEditor,
          [
            ...conversationHistory
          ]
        );
        conversationHistory.push(...humanTextureEditorResultTemp.newItems.map((item) => item.rawItem));

        if (!humanTextureEditorResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const humanTextureEditorResult = {
          output_text: JSON.stringify(humanTextureEditorResultTemp.finalOutput),
          output_parsed: humanTextureEditorResultTemp.finalOutput
        };
        const trustFactualEditorResultTemp = await runner.run(
          trustFactualEditor,
          [
            ...conversationHistory
          ]
        );
        conversationHistory.push(...trustFactualEditorResultTemp.newItems.map((item) => item.rawItem));

        if (!trustFactualEditorResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const trustFactualEditorResult = {
          output_text: JSON.stringify(trustFactualEditorResultTemp.finalOutput),
          output_parsed: trustFactualEditorResultTemp.finalOutput
        };
        const emotionalResonanceEvaluatorResultTemp = await runner.run(
          emotionalResonanceEvaluator,
          [
            ...conversationHistory
          ]
        );
        conversationHistory.push(...emotionalResonanceEvaluatorResultTemp.newItems.map((item) => item.rawItem));

        if (!emotionalResonanceEvaluatorResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const emotionalResonanceEvaluatorResult = {
          output_text: JSON.stringify(emotionalResonanceEvaluatorResultTemp.finalOutput),
          output_parsed: emotionalResonanceEvaluatorResultTemp.finalOutput
        };
        const readerSimulationResultTemp = await runner.run(
          readerSimulation,
          [
            ...conversationHistory
          ]
        );
        conversationHistory.push(...readerSimulationResultTemp.newItems.map((item) => item.rawItem));

        if (!readerSimulationResultTemp.finalOutput) {
            throw new Error("Agent result is undefined");
        }

        const readerSimulationResult = {
          output_text: JSON.stringify(readerSimulationResultTemp.finalOutput),
          output_parsed: readerSimulationResultTemp.finalOutput
        };
        const approvalMessage1 = `Approve or reject this article before publishing.

      Approve if:
      - reader trust is likely to increase
      - the reader would likely continue reading
      - no major confusion, skepticism, or emotional fatigue appears
      - the article feels calm, useful, and non-salesy

      Reject if:
      - the reader is confused or overwhelmed
      - the reader becomes skeptical
      - the article feels salesy, generic, or emotionally forced
      - unanswered questions would block publication

      Reader verdict:
      ${readerSimulationResult.output_parsed.final_reader_verdict}

      Continue reading likelihood:
      ${readerSimulationResult.output_parsed.continue_reading_likelihood}

      Brand trust effect:
      ${readerSimulationResult.output_parsed.purchase_or_brand_trust_effect}

      Reader concerns:
      ${readerSimulationResult.output_parsed.where_reader_becomes_skeptical}

      Confusion points:
      ${readerSimulationResult.output_parsed.where_reader_feels_confused}

      Drop-off points:
      ${readerSimulationResult.output_parsed.likely_drop_off_points}

      Unanswered questions:
      ${readerSimulationResult.output_parsed.reader_questions_left_unanswered}`;

        if (approvalRequest1(approvalMessage1)) {
            const endResult = {
              slug: readerSimulationResult.output_parsed.slug,
              title: readerSimulationResult.output_parsed.title,
              content: state.articlemd,
              overwrite: true,
              publishDate: readerSimulationResult.output_parsed.publishDate,
              draft: false,
              author: readerSimulationResult.output_parsed.author,
              tags: [],
              excerpt: readerSimulationResult.output_parsed.excerpt,
              seoDescription: readerSimulationResult.output_parsed.seoDescription,
              category: readerSimulationResult.output_parsed.category,
              featuredImage: readerSimulationResult.output_parsed.featuredImage,
              commitMessage: readerSimulationResult.output_parsed.commitMessage
            };
            return endResult;
        } else {
            const endResult = {
              available_output: {

              },
              article_state: state.articlemd
            };
            return endResult;
        }
    } else {
        const endResult = {
          available_output: {

          },
          article_state: state.articlemd
        };
        return endResult;
    }
  });
}
