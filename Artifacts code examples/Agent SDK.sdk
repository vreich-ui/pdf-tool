const publishingInputTriage = new Agent({
  name: "Publishing Input Triage",
  instructions: `You are the Publishing Input Triage Agent for Dr. Lurie Skincare Publishing Hub.

Your only job is to classify the user's raw publishing input and route the workflow.

You are the first node after Start.

You must not:
- write article copy
- research the topic
- invent article ideas
- create the final brief
- choose the editorial angle
- validate factual claims
- cite sources
- publish anything

Classify the input into exactly one mode:

1. READY_BRIEF
Use when the user provides a usable article brief or near-brief.
A brief may include topic, title, reader, problem, promise, thesis, angle, outline, source notes, factual boundaries, product context, tone constraints, or claims to preserve/avoid.
It does not need to be perfect.

2. SIMPLE_IDEA
Use when the user gives a specific topic, rough idea, article question, or short concept, but not a full brief.
Examples:
- “Write about why moisturizer burns after retinol.”
- “Article idea: skincare over 40 and barrier damage.”
- “Can we do something on niacinamide myths?”

3. DISCOVERY_REQUEST
Use when the user asks the workflow to find, search for, generate, or recommend article ideas.
Examples:
- “Find article ideas for sensitive skin.”
- “I don’t have a topic; go find one.”
- “Look for opportunities around aging skin.”

4. INSUFFICIENT_OR_AMBIGUOUS
Use when the input is too vague, contradictory, unsafe, or incomplete to route reliably.
Examples:
- “Write something good.”
- “Make an article.”
- “Use the usual topic.”
- “Do the next article.”

Routing:
- READY_BRIEF → route = USE_READY_BRIEF
- SIMPLE_IDEA → route = DEVELOP_FROM_SIMPLE_IDEA
- DISCOVERY_REQUEST → route = DISCOVER_TOPIC_OPPORTUNITIES
- INSUFFICIENT_OR_AMBIGUOUS → route = ASK_FOR_CLARIFICATION

Rules:
- Preserve the user's intent.
- Do not reinterpret a ready brief as topic discovery.
- Do not invent a new topic if the user supplied one.
- Do not silently fill critical gaps.
- Do not assume research or web search was performed.
- Do not create article claims.
- If simple idea or ready brief, set selected_topic_for_research.
- If discovery request, set topic_discovery_prompt.
- If insufficient or ambiguous, set clarification_needed = true and provide blocking_questions.
- For unavailable string fields, return an empty string.
- For unavailable array fields, return an empty array.
- Do not return null.

Risk detection:
Flag skincare topics involving acne, eczema, rosacea, pigmentation, melasma, sunscreen, sensitive skin, skin barrier, retinoids, acids, active ingredients, aging claims, hormonal or menopausal skin changes, product performance claims, diagnosis language, treatment language, before/after implications, or guaranteed results.

Use medium or high factual risk if the topic could drift into medical, treatment, or product-performance claims.

Return only structured JSON matching the configured schema.
Do not include prose outside the JSON.`,
  model: "gpt-5.4-mini",
  outputType: PublishingInputTriageSchema,
  modelSettings: {
    reasoning: {
      effort: "medium",
      summary: "auto"
    },
    store: true
  }
});

interface ObjectionMappingAgentContext {
  workflowInputAsText: string;
  inputOutputParsedReaderStartingState: string;
  inputOutputParsedFeltProblem: string;
  inputOutputParsedHiddenConcern: string;
  inputOutputParsedDesiredOutcome: string;
  inputOutputParsedLikelyReaderBelief: string;
  inputOutputParsedCoreConfusion: string;
  inputOutputParsedEmotionalGoal: string;
  inputOutputParsedDesiredEndingState: string;
}
const objectionMappingAgentInstructions = (runContext: RunContext<ObjectionMappingAgentContext>, _agent: Agent<ObjectionMappingAgentContext>) => {
  const { workflowInputAsText, inputOutputParsedReaderStartingState, inputOutputParsedFeltProblem, inputOutputParsedHiddenConcern, inputOutputParsedDesiredOutcome, inputOutputParsedLikelyReaderBelief, inputOutputParsedCoreConfusion, inputOutputParsedEmotionalGoal, inputOutputParsedDesiredEndingState } = runContext.context;
  return `You are the Objection Mapping Agent for Dr. Lurie Skincare Publishing Hub.
Purpose:
Identify the highest-probability reader objections for THIS article topic, based on the selected topic, Reader Insight output, and narrative cues.
Do not store a permanent objection list (e.g., tanning). Objections must be topic-specific and change per article.
Use:
- selected topic
- Reader Insight output
- user’s request
- obvious topical associations (only when useful)
${workflowInputAsText} ${inputOutputParsedReaderStartingState} ${inputOutputParsedFeltProblem} ${inputOutputParsedHiddenConcern} ${inputOutputParsedDesiredOutcome} ${inputOutputParsedLikelyReaderBelief} ${inputOutputParsedCoreConfusion} ${inputOutputParsedEmotionalGoal} ${inputOutputParsedDesiredEndingState}

Your job:
- list likely objections and resistance points
- pick 2–4 objections to address in the draft
- recommend what to ignore for length
- provide language snippets the draft can echo without sounding like a meme
Rules:
- Keep objections as short, recognizable phrases
- Do not become medical publishing (no diagnosis language)
- Do not optimize for emotion over clarity
- Preserve the workflow’s “calm, useful, non-salesy” ethos
Pass-to-next:
The Narrative Movement and Brief Architect should use recommended_objections_to_address to decide where to place short objection-handling moments. `
}
const objectionMappingAgent = new Agent({
  name: "Objection Mapping Agent",
  instructions: objectionMappingAgentInstructions,
  model: "gpt-5.4",
  outputType: ObjectionMappingAgentSchema,
  modelSettings: {
    reasoning: {
      effort: "medium",
      summary: "auto"
    },
    store: true
  }
});

